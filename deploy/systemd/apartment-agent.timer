[Unit]
Description=Run the Munich apartment-hunter agent every 3 hours

[Timer]
# Every 3 hours on the clock, plus up to 20 min jitter to look less bot-like.
OnCalendar=*-*-* 00/3:00:00
RandomizedDelaySec=1200
# Run once on boot if a scheduled run was missed while powered off.
Persistent=true

[Install]
WantedBy=timers.target
