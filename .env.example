# ---- Copy to .env and fill in. NEVER commit the real .env. ----

# --- LLM tiers (mirror the customOpenClaw philosophy) ---
# tier1 = cheap/free (OpenRouter), tier2 = medium (OpenCode Zen), tier3 = hard (Anthropic)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Comma-separated; the router rotates through them on rate-limit (free models throttle hard)
TIER1_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free

OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
# Confirm the exact id ("big pickle"?) against the live /models catalog
TIER2_MODEL=

ANTHROPIC_API_KEY=
# claude-sonnet-4-6 (cost) or claude-opus-4-6 (max capability)
TIER3_MODEL=claude-sonnet-4-6

# --- Database (Supabase) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Notifications (Telegram) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Search filters (override defaults if desired) ---
MAX_WARM_RENT_EUR=700
MIN_SIZE_SQM=12
MOVE_IN_DATE=2026-10-01
# wg_room, apartment, or both (comma-separated)
LISTING_TYPES=wg_room,apartment

# --- Behavior ---
DRY_RUN=false
ENABLE_LLM_ENRICH=true
LOG_LEVEL=INFO
