# ---- Copy to .env and fill in. NEVER commit the real .env. ----

# --- LLM tiers (mirror the customOpenClaw philosophy) ---
# tier1 = cheap/free (OpenRouter), tier2 = medium (OpenCode Zen), tier3 = hard (Claude)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Comma-separated; the router rotates through them and escalates on rate-limit/error.
# (Free OpenRouter models throttle hard — keep a couple, and tier2 covers the gaps.)
TIER1_MODELS=meta-llama/llama-3.3-70b-instruct:free

OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
# Paid Zen models (e.g. "big-pickle", "claude-opus-4-7") need a Zen payment method.
# Without one, use a free model such as "nemotron-3-super-free".
TIER2_MODEL=nemotron-3-super-free

# Optional: set ANTHROPIC_API_KEY to route the hard tier directly to Anthropic.
# If empty, the hard tier is served via OpenCode Zen's Claude (needs Zen credits).
ANTHROPIC_API_KEY=
# Anthropic id (e.g. claude-sonnet-4-6) if ANTHROPIC_API_KEY is set, else a Zen id.
TIER3_MODEL=claude-opus-4-7

# --- Database (Supabase) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Notifications (Telegram) ---
# chat id must be NUMERIC (your user id) or an @channel the bot can post to — NOT the bot's username.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Search filters (override defaults if desired) ---
MAX_WARM_RENT_EUR=700
MIN_SIZE_SQM=12
MOVE_IN_DATE=2026-10-01
# wg_room, apartment, or both (comma-separated)
LISTING_TYPES=wg_room,apartment

# --- Behavior ---
DRY_RUN=false
ENABLE_LLM_ENRICH=true
LOG_LEVEL=INFO
