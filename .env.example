# ---- Copy to .env and fill in. NEVER commit the real .env. ----

# --- LLM tiers (mirror the customOpenClaw philosophy) ---
# tier1 = cheap/fast, tier2 = medium, tier3 = hard. tier1 + tier2 run on OpenCode Zen free models.
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
# tier1: fast free models (comma-separated; router rotates + escalates on error)
TIER1_MODELS=deepseek-v4-flash-free,mimo-v2.5-free
# tier2: stronger free model
TIER2_MODEL=nemotron-3-ultra-free

# OpenRouter is optional/legacy (its free models were rate-limited/deprecated). Leave blank to skip.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: set ANTHROPIC_API_KEY to route the hard tier directly to Anthropic.
# If empty, the hard tier is served via OpenCode Zen's Claude (needs Zen credits).
ANTHROPIC_API_KEY=
# Anthropic id (e.g. claude-sonnet-4-6) if ANTHROPIC_API_KEY is set, else a Zen id.
TIER3_MODEL=claude-opus-4-7

# --- Database (Supabase) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Notifications (Telegram) ---
# chat id must be NUMERIC (your user id) or an @channel the bot can post to — NOT the bot's username.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Search filters (override defaults if desired) ---
MAX_WARM_RENT_EUR=700
MIN_SIZE_SQM=12
MOVE_IN_DATE=2026-10-01
# wg_room, apartment, or both (comma-separated)
LISTING_TYPES=wg_room,apartment

# --- Behavior ---
DRY_RUN=false
# Fetch each new listing's detail page to resolve the true Warmmiete/Kaltmiete before the final
# filter (the search card only shows one ambiguous figure). false -> filter on the listed figure.
ENABLE_DETAIL_FETCH=true
ENABLE_LLM_ENRICH=true
# Human-in-the-loop: send one message per listing so 👍/👎 reactions map to a listing; sync with
# `python -m apartment_agent.main --sync-feedback` and the wiki preferences page learns from them.
ENABLE_FEEDBACK=true
# Durable execution: persist graph state so an interrupted run resumes on next start.
ENABLE_CHECKPOINTING=true
CHECKPOINT_DB=agent_state.sqlite
LOG_LEVEL=INFO

# --- Observability (optional) ---
# Per-run metrics (timings, token usage) persist to the `runs` table automatically.
# For full LLM tracing, set these to stream spans to LangSmith (langsmith is already installed):
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=munich-apartment-agent

# --- Knowledge wiki (Karpathy "LLM Wiki" layer; see WIKI_SCHEMA.md) ---
# Maintain synthesized, interlinked markdown pages on top of the raw listings.
ENABLE_WIKI=true
# Output dir (gitignored; persists across `git reset --hard` redeploys).
WIKI_DIR=wiki
